{
  "name": "claude-code-line",
  "version": "1.0.8",
  "description": "Minimal, customizable statusline for Claude Code CLI",
  "type": "module",
  "bin": {
    "claude-code-line": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node node_modules/esbuild/bin/esbuild app/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:react-devtools-core --packages=external \"--define:process.env.NODE_ENV=\\\"production\\\"\" && node scripts/shebang.js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "statusline",
    "status-line",
    "terminal",
    "tui"
  ],
  "author": "yasir-ali9",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasir-ali9/claude-code-line.git"
  },
  "homepage": "https://github.com/yasir-ali9/claude-code-line",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.0",
    "@types/react": "^18.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
